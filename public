
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>NFC-e Leitor SP</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jsQR/1.4.0/jsQR.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#F3F1EA;--surface:#FFF;--surface2:#F8F7F3;
  --border:#E3DFD5;--border2:#C9C4B8;
  --text:#18160F;--muted:#78746A;
  --green:#1A5C35;--green-bg:#EAF3ED;--green-txt:#144D2B;
  --red:#8B1F1F;--red-bg:#FDF0F0;
  --sans:'DM Sans',sans-serif;--mono:'IBM Plex Mono',monospace;
  --r:10px;--rl:16px;
}
body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;padding-bottom:5rem;}

/* HEADER */
.hdr{background:var(--surface);border-bottom:1px solid var(--border);height:54px;display:flex;align-items:center;justify-content:space-between;padding:0 1.25rem;position:sticky;top:0;z-index:10;}
.hdr-logo{display:flex;align-items:center;gap:10px;}
.hdr-icon{width:30px;height:30px;background:var(--green);border-radius:7px;display:flex;align-items:center;justify-content:center;}
.hdr-icon svg{width:17px;height:17px;stroke:#fff;fill:none;stroke-width:2.2;}
.hdr-name{font-size:14px;font-weight:500;letter-spacing:-.02em;}
.hdr-sub{font-size:10px;color:var(--muted);font-family:var(--mono);}
.hdr-pill{background:var(--green-bg);color:var(--green-txt);font-size:10px;font-family:var(--mono);padding:3px 10px;border-radius:99px;border:1px solid #C0DCC8;}

/* LAYOUT */
.wrap{max-width:620px;margin:0 auto;padding:1.5rem 1rem;}

/* CARDS */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--rl);padding:1.25rem;margin-bottom:10px;}
.lbl{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);font-family:var(--mono);margin-bottom:10px;}

/* INPUTS */
.row{display:flex;gap:8px;}
input[type=text]{flex:1;font-family:var(--sans);font-size:13px;padding:10px 13px;border:1px solid var(--border);border-radius:var(--r);background:var(--surface2);color:var(--text);outline:none;transition:border-color .15s,background .15s;min-width:0;}
input[type=text]::placeholder{color:var(--muted);}
input[type=text]:focus{border-color:var(--green);background:var(--surface);}

/* BUTTONS */
button{font-family:var(--sans);font-size:13px;font-weight:500;padding:10px 16px;border-radius:var(--r);border:1px solid var(--border2);background:var(--surface);color:var(--text);cursor:pointer;transition:all .12s;white-space:nowrap;display:inline-flex;align-items:center;gap:6px;}
button:hover{background:var(--surface2);border-color:var(--green);color:var(--green);}
button:active{transform:scale(.98);}
button.pri{background:var(--green);color:#fff;border-color:var(--green);}
button.pri:hover{background:#144D2B;border-color:#144D2B;color:#fff;}
button.sm{font-size:11px;padding:5px 11px;}
button.ghost{border-color:transparent;background:transparent;}
button.ghost:hover{background:var(--surface2);border-color:var(--border);}

/* DIVIDER */
.div{display:flex;align-items:center;gap:10px;margin:12px 0;}
.div::before,.div::after{content:'';flex:1;height:1px;background:var(--border);}
.div span{font-size:11px;color:var(--muted);font-family:var(--mono);}

/* CAMERA */
.cam-area{position:relative;border:1px solid var(--border);border-radius:var(--r);overflow:hidden;background:var(--surface2);min-height:190px;display:flex;align-items:center;justify-content:center;margin-top:12px;}
.cam-ph{text-align:center;padding:2rem 1rem;}
.cam-ph p{font-size:13px;color:var(--muted);margin-bottom:14px;}
#video{width:100%;max-height:300px;object-fit:cover;display:none;}
#qr-canvas{display:none;}
#stop-btn{display:none;position:absolute;top:8px;right:8px;font-size:11px;padding:4px 10px;background:rgba(255,255,255,.9);backdrop-filter:blur(6px);}
.scan-line{display:none;position:absolute;left:8%;right:8%;height:2px;background:var(--green);border-radius:2px;animation:scanMove 2s ease-in-out infinite;opacity:.8;}
@keyframes scanMove{0%{top:10%}50%{top:86%}100%{top:10%}}
#status{font-size:11px;color:var(--muted);font-family:var(--mono);margin-top:7px;min-height:17px;}

/* ALERT */
.alert-warn{background:#FEF9EC;border:1px solid #F0DFA0;border-radius:var(--rl);padding:.75rem 1rem;margin-bottom:10px;font-size:12px;color:#7A5800;}

/* LOADING */
#loading{display:none;text-align:center;padding:3.5rem 1rem;}
.spin{width:30px;height:30px;border:2px solid var(--border);border-top-color:var(--green);border-radius:50%;animation:spin .7s linear infinite;margin:0 auto 14px;}
@keyframes spin{to{transform:rotate(360deg)}}
#loading p{font-size:13px;color:var(--muted);}
#loading small{font-size:11px;color:var(--muted);font-family:var(--mono);display:block;margin-top:4px;}

/* ERROR */
#errbox{display:none;background:var(--red-bg);border:1px solid #F5C0C0;border-radius:var(--rl);padding:1rem 1.25rem;margin-bottom:10px;}
#errbox p{font-size:13px;color:var(--red);margin-bottom:10px;}

/* RESULT */
#result{display:none;}
.res-bar{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.res-bar span{font-size:14px;font-weight:500;}
.badge{display:inline-flex;align-items:center;gap:5px;background:var(--green-bg);color:var(--green-txt);font-size:10px;font-family:var(--mono);padding:3px 10px;border-radius:99px;border:1px solid #C0DCC8;}
.badge::before{content:'';width:6px;height:6px;background:var(--green);border-radius:50%;}

.emit-name{font-size:17px;font-weight:500;margin-bottom:3px;letter-spacing:-.02em;}
.emit-sub{font-size:13px;color:var(--muted);margin-bottom:2px;}
.emit-end{font-size:12px;color:var(--muted);}

.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:8px;margin-top:10px;}
.metric{background:var(--surface2);border-radius:var(--r);padding:.75rem 1rem;border:1px solid var(--border);}
.m-lbl{font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:4px;font-family:var(--mono);}
.m-val{font-size:15px;font-weight:500;}
.m-val.big{font-size:22px;color:var(--green);}

.tbl{width:100%;border-collapse:collapse;}
.tbl tr:not(:last-child) td{border-bottom:1px solid var(--border);}
.tbl td{padding:10px 0;vertical-align:top;font-size:13px;}
.iname{font-weight:500;display:block;margin-bottom:2px;}
.idet{font-size:11px;color:var(--muted);font-family:var(--mono);}
.ival{text-align:right;font-weight:500;white-space:nowrap;padding-left:12px;min-width:80px;}

.kv{display:flex;justify-content:space-between;font-size:13px;padding:5px 0;gap:12px;}
.kv:not(:last-child){border-bottom:1px solid var(--border);}
.kk{color:var(--muted);flex-shrink:0;}
.kv-val{font-weight:500;text-align:right;word-break:break-all;}

.chave{font-family:var(--mono);font-size:11px;color:var(--muted);word-break:break-all;line-height:1.8;}
.proto{font-size:11px;color:var(--muted);font-family:var(--mono);margin-top:6px;}

.extras-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:6px;margin-top:4px;}
.extra-item{background:var(--surface2);border:1px solid var(--border);border-radius:var(--r);padding:.6rem .85rem;}
.extra-k{font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);font-family:var(--mono);margin-bottom:3px;}
.extra-v{font-size:13px;font-weight:500;}

footer{text-align:center;margin-top:1.5rem;font-size:11px;color:var(--muted);font-family:var(--mono);}
footer a{color:var(--green-txt);text-decoration:none;}
</style>
</head>
<body>

<header class="hdr">
  <div class="hdr-logo">
    <div class="hdr-icon">
      <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="3" height="3" rx=".5"/><rect x="18" y="14" width="3" height="3" rx=".5"/><rect x="14" y="18" width="3" height="3" rx=".5"/><rect x="18" y="18" width="3" height="3" rx=".5"/></svg>
    </div>
    <div>
      <div class="hdr-name">NFC-e Leitor SP</div>
      <div class="hdr-sub">Sefaz · sem API key</div>
    </div>
  </div>
  <div class="hdr-pill">scraping direto</div>
</header>

<div class="wrap">

  <!-- SCANNER -->
  <div id="scanner-section">
    <div class="card">
      <p class="lbl">URL do QR Code</p>
      <div class="row">
        <input type="text" id="url-input" placeholder="https://www.nfce.fazenda.sp.gov.br/..."/>
        <button class="pri" onclick="consultar()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          Consultar
        </button>
      </div>

      <div class="div"><span>ou escaneie com a câmera</span></div>

      <div class="cam-area" id="cam-area">
        <div class="cam-ph" id="cam-ph">
          <svg width="50" height="50" viewBox="0 0 50 50" fill="none" style="display:block;margin:0 auto 12px;opacity:.22;">
            <rect x="2" y="2" width="17" height="17" rx="2" stroke="currentColor" stroke-width="2"/>
            <rect x="6" y="6" width="9" height="9" rx="1" fill="currentColor"/>
            <rect x="31" y="2" width="17" height="17" rx="2" stroke="currentColor" stroke-width="2"/>
            <rect x="35" y="6" width="9" height="9" rx="1" fill="currentColor"/>
            <rect x="2" y="31" width="17" height="17" rx="2" stroke="currentColor" stroke-width="2"/>
            <rect x="6" y="35" width="9" height="9" rx="1" fill="currentColor"/>
            <rect x="31" y="31" width="4" height="4" rx=".5" fill="currentColor"/>
            <rect x="39" y="31" width="4" height="4" rx=".5" fill="currentColor"/>
            <rect x="31" y="39" width="4" height="4" rx=".5" fill="currentColor"/>
            <rect x="39" y="39" width="4" height="4" rx=".5" fill="currentColor"/>
          </svg>
          <p>Aponte a câmera para o QR Code da NFC-e</p>
          <button onclick="startCamera()">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            Abrir câmera
          </button>
        </div>
        <video id="video" playsinline></video>
        <canvas id="qr-canvas"></canvas>
        <div class="scan-line" id="scan-line"></div>
        <button id="stop-btn" class="sm" onclick="stopCamera()">✕ Parar</button>
      </div>
      <div id="status"></div>
    </div>

    <div class="alert-warn">⚡ A URL do QR Code expira em algumas horas. Consulte logo após escanear a nota.</div>
  </div>

  <!-- LOADING -->
  <div id="loading">
    <div class="spin"></div>
    <p>Consultando a Sefaz SP...</p>
    <small>fazendo scraping direto da página</small>
  </div>

  <!-- ERROR -->
  <div id="errbox">
    <p id="errmsg"></p>
    <button class="sm" onclick="resetApp()">Tentar novamente</button>
  </div>

  <!-- RESULT -->
  <div id="result">
    <div class="res-bar">
      <div class="badge">NFC-e autorizada</div>
      <button class="sm ghost" onclick="resetApp()">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.99"/></svg>
        Nova consulta
      </button>
    </div>

    <div class="card">
      <p class="lbl">Emitente</p>
      <p class="emit-name" id="r-nome">—</p>
      <p class="emit-sub"  id="r-cnpj">—</p>
      <p class="emit-end"  id="r-end">—</p>
    </div>

    <div class="card">
      <div class="metrics">
        <div class="metric"><div class="m-lbl">Nº / Série</div><div class="m-val" id="r-num">—</div></div>
        <div class="metric"><div class="m-lbl">Emissão</div><div class="m-val" id="r-data">—</div></div>
        <div class="metric"><div class="m-lbl">Total a pagar</div><div class="m-val big" id="r-total">—</div></div>
      </div>
    </div>

    <div class="card">
      <p class="lbl" id="r-itens-lbl">Itens</p>
      <table class="tbl" id="r-itens"></table>
    </div>

    <div class="card">
      <p class="lbl">Pagamento</p>
      <div id="r-pag"></div>
    </div>

    <div class="card" id="r-cons-card">
      <p class="lbl">Consumidor</p>
      <div id="r-cons"></div>
    </div>

    <div class="card" id="r-extras-card" style="display:none;">
      <p class="lbl">Veículo / Entrega</p>
      <div class="extras-grid" id="r-extras"></div>
    </div>

    <div class="card" id="r-trib-card" style="display:none;">
      <p class="lbl">Tributos (Lei 12.741/2012)</p>
      <div id="r-trib"></div>
    </div>

    <div class="card">
      <p class="lbl">Chave de acesso</p>
      <p class="chave" id="r-chave">—</p>
      <p class="proto" id="r-proto"></p>
    </div>
  </div>

  <footer>
    Scraping direto da <a href="https://www.nfce.fazenda.sp.gov.br" target="_blank">Sefaz SP</a> &nbsp;·&nbsp; nenhum dado é armazenado
  </footer>
</div>

<script>
// ── CONFIG ──────────────────────────────────────────────────────────────────
// Detecta se está rodando local ou em produção (Netlify/Vercel/etc.)
// Ajuste ENDPOINT se precisar de rota diferente.
const ENDPOINT = '/api/consultar';

// ── CAMERA ──────────────────────────────────────────────────────────────────
let stream = null, scanTick = null;

function $id(id){ return document.getElementById(id); }
function setStatus(t){ $id('status').textContent = t; }

function startCamera(){
  navigator.mediaDevices.getUserMedia({ video:{ facingMode:'environment' } })
    .then(s => {
      stream = s;
      const v = $id('video');
      v.srcObject = s; v.play();
      v.style.display = 'block';
      $id('cam-ph').style.display   = 'none';
      $id('stop-btn').style.display = 'block';
      $id('scan-line').style.display = 'block';
      setStatus('Aponte para o QR Code da NFC-e...');
      scanTick = setInterval(scanFrame, 250);
    })
    .catch(() => setStatus('Câmera não disponível — cole a URL manualmente.'));
}

function stopCamera(){
  if(stream){ stream.getTracks().forEach(t => t.stop()); stream = null; }
  clearInterval(scanTick);
  $id('video').style.display    = 'none';
  $id('cam-ph').style.display   = 'block';
  $id('stop-btn').style.display  = 'none';
  $id('scan-line').style.display = 'none';
  setStatus('');
}

function scanFrame(){
  const v = $id('video');
  if(v.readyState !== v.HAVE_ENOUGH_DATA) return;
  const c = $id('qr-canvas');
  c.width = v.videoWidth; c.height = v.videoHeight;
  c.getContext('2d').drawImage(v,0,0);
  const img = c.getContext('2d').getImageData(0,0,c.width,c.height);
  const code = jsQR(img.data, img.width, img.height);
  if(code && code.data.startsWith('http')){
    stopCamera();
    $id('url-input').value = code.data;
    setStatus('✓ QR Code lido — consultando...');
    setTimeout(consultar, 600);
  }
}

// ── CONSULTA ────────────────────────────────────────────────────────────────
async function consultar(){
  const url = $id('url-input').value.trim();
  if(!url){ setStatus('Informe a URL da NFC-e.'); return; }

  $id('scanner-section').style.display = 'none';
  $id('loading').style.display  = 'block';
  $id('errbox').style.display   = 'none';
  $id('result').style.display   = 'none';

  try {
    const res  = await fetch(ENDPOINT, {
      method: 'POST',
      headers: { 'Content-Type':'application/json' },
      body: JSON.stringify({ url })
    });
    const data = await res.json();
    if(data.erro) throw new Error(data.erro);
    render(data);
  } catch(e){
    $id('loading').style.display          = 'none';
    $id('scanner-section').style.display  = 'block';
    $id('errbox').style.display           = 'block';
    $id('errmsg').textContent             = e.message || 'Erro desconhecido.';
  }
}

// ── RENDER ──────────────────────────────────────────────────────────────────
function set(id, val){ const el = $id(id); if(el) el.textContent = val || '—'; }

function kv(key, val, last){
  return `<div class="kv"${last?' style="border:none"':''}><span class="kk">${key}</span><span class="kv-val">${val||'—'}</span></div>`;
}

function render(d){
  $id('loading').style.display = 'none';

  set('r-nome', d.emitente?.nome);
  set('r-cnpj', d.emitente?.cnpj ? 'CNPJ: ' + d.emitente.cnpj : '—');
  set('r-end',  d.emitente?.endereco);
  set('r-num',  [d.numero, d.serie].filter(Boolean).join(' / '));
  set('r-data', d.data);
  set('r-total', d.totais?.total ? 'R$ ' + d.totais.total : '—');
  set('r-chave', d.chave);
  set('r-proto', d.protocolo ? 'Protocolo: ' + d.protocolo : '');

  // Itens
  const itens = d.itens || [];
  $id('r-itens-lbl').textContent = `Itens (${itens.length})`;
  $id('r-itens').innerHTML = itens.map(it => `
    <tr>
      <td>
        <span class="iname">${it.descricao||'—'}</span>
        <span class="idet">${[it.qtd,it.un].filter(Boolean).join(' ')}${it.vl_unit?' · R$ '+it.vl_unit+'/un':''}</span>
      </td>
      <td class="ival">R$ ${it.vl_total||'—'}</td>
    </tr>`).join('');

  // Pagamentos
  $id('r-pag').innerHTML = (d.pagamentos||[]).map((p,i,a) =>
    kv(p.tipo, 'R$ '+p.valor, i===a.length-1)).join('');

  // Consumidor
  const c = d.consumidor;
  $id('r-cons').innerHTML = (c && (c.nome||c.cnpj_cpf)) ? [
    c.nome      && kv('Nome',     c.nome),
    c.cnpj_cpf  && kv('CNPJ/CPF',c.cnpj_cpf),
    c.endereco  && kv('Endereço', c.endereco, true),
  ].filter(Boolean).join('') : '<p style="font-size:13px;color:var(--muted)">Consumidor não identificado</p>';

  // Extras (veículo, placa, etc.)
  const ex = d.extras;
  const extraItems = ex ? [
    ex.veiculo  && { k:'Veículo',   v:ex.veiculo },
    ex.placa    && { k:'Placa',     v:ex.placa },
    ex.km       && { k:'KM',        v:ex.km },
    ex.condutor && { k:'Condutor',  v:ex.condutor },
    ex.vendedor && { k:'Vendedor',  v:ex.vendedor },
  ].filter(Boolean) : [];

  if(extraItems.length){
    $id('r-extras-card').style.display = 'block';
    $id('r-extras').innerHTML = extraItems.map(e =>
      `<div class="extra-item"><div class="extra-k">${e.k}</div><div class="extra-v">${e.v}</div></div>`).join('');
  }

  // Tributos
  const tr = d.tributos;
  if(tr && tr.total){
    $id('r-trib-card').style.display = 'block';
    $id('r-trib').innerHTML = [
      kv('Total aprox.', 'R$ '+tr.total),
      tr.federal  && kv('Federal',  'R$ '+tr.federal),
      tr.estadual && kv('Estadual', 'R$ '+tr.estadual, true),
    ].filter(Boolean).join('');
  }

  $id('result').style.display = 'block';
}

// ── RESET ────────────────────────────────────────────────────────────────────
function resetApp(){
  $id('url-input').value = '';
  setStatus('');
  $id('result').style.display          = 'none';
  $id('errbox').style.display          = 'none';
  $id('loading').style.display         = 'none';
  $id('scanner-section').style.display = 'block';
  $id('r-extras-card').style.display   = 'none';
  $id('r-trib-card').style.display     = 'none';
}

$id('url-input').addEventListener('keydown', e => { if(e.key==='Enter') consultar(); });
</script>
</body>
</html>
